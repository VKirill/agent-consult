{
  "name": "agent-consult-mcp-server",
  "version": "1.4.0",
  "description": "MCP server for multi-agent AI consultations (Codex, Claude, Anti-Gravity, Mimo) with consensus synthesis",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --experimental-strip-types src/index.ts",
    "test": "vitest run",
    "diagnose:ping": "node dist/ping-agents.js",
    "diagnose:mcp": "node --experimental-strip-types scripts/test-mcp-direct.ts",
    "diagnose:dynamic-mcp": "node --experimental-strip-types scripts/test-dynamic-mcp.ts",
    "diagnose:full": "node --experimental-strip-types scripts/test-full-consult.ts",
    "diagnose:local": "node --experimental-strip-types scripts/test-local.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "ai-agents",
    "multi-agent",
    "claude-desktop",
    "codex-cli",
    "openrouter",
    "minimax-m3",
    "synthesis",
    "typescript",
    "nodejs"
  ],
  "author": "Kirill Vechkasov (https://github.com/VKirill)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VKirill/agent-consult.git"
  },
  "bugs": {
    "url": "https://github.com/VKirill/agent-consult/issues"
  },
  "homepage": "https://github.com/VKirill/agent-consult#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.9"
  }
}
